WHITESPACE = _{ " " | "\t" | "\r" | "\n" }

string_literal = @{ "\"" ~ inner ~ "\"" }
inner = @{ char* }
char = {
    !("\"" | "\\") ~ ANY
    | "\\" ~ ("\"" | "\\" | "/" | "b" | "f" | "n" | "r" | "t")
    | "\\" ~ ("u" ~ ASCII_HEX_DIGIT{4})
}

property = { string_literal ~ string_literal }
block = { "{" ~ property* ~ "}" }
blocks = _{ SOI ~ block* ~ EOI }
